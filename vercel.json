{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/rightmove", "dest": "/api/rightmove.js" },
    { "src": "/api/epc", "dest": "/api/epc.js" },
    { "src": "/api/anthropic", "dest": "/api/anthropic.js" },
    { "src": "/api/config", "dest": "/api/config.js" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
